# --- Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# --- Web origin (CORS)
WEB_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Neon Postgres
# Pooled connection (used at runtime) — host has -pooler suffix
DATABASE_URL=postgres://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/dogget-db?sslmode=require
# Direct connection (used by Prisma migrate only)
DIRECT_URL=postgres://USER:PASS@ep-xxx.REGION.aws.neon.tech/dogget-db?sslmode=require

# --- Firebase Admin
# Base64-encoded service-account JSON (one line, no newlines)
# Generate: cat service-account.json | base64 | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_PROJECT_ID=dogget-a8eb8

# --- Sentry (optional during Phase 1)
SENTRY_DSN=
